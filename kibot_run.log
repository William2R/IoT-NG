        sheet_reference_color: '#000000'
        colored_holes: true
        holes_color: "#FFFFFF"
        layers:
          - layer: Edge.Cuts
            color: '#000000'
          - layer: F.Cu
            color: '#E5E5E5'
          - layer: F.Mask
            color: '#CECECE'
          - layer: F.Paste
            color: '#CECECE'
          - layer: F.Silkscreen
            color: '#C7C7C7'
          - layer: F.Fab
            exclude_filter: 'only_testpoints'
            plot_footprint_values: false
            sketch_pads_on_fab_layers: false
            color: '#E10000'
