# KiBot output for MD Report (e.g. README.md)
# https://kibot.readthedocs.io/en/latest/configuration/outputs/report.html

kibot:
  version: 1

outputs:
  - name: md_readme
    comment: 'README file in Markdown format'
    type: report
    category: '.'
    dir: './'
    options:
      output: 'README.md'
      template: kibot_resources/templates/readme.txt

